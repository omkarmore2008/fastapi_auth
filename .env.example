# App
APP_NAME=FastAPI Auth Template
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change_me_to_a_strong_secret_123
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_EXPIRE_MINUTES=30
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=5

# Database
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app_db
POSTGRES_HOST_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST_PORT=6379

# Mail (Mailpit local)
MAIL_FROM=noreply@example.com
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=false
SMTP_SSL_TLS=false
MAILPIT_SMTP_HOST_PORT=1025
MAILPIT_UI_HOST_PORT=8025

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=app-local-bucket
AWS_S3_ENDPOINT_URL=http://minio:9000

# API / Compose
API_HOST_PORT=8000
MIGRATION_MESSAGE=auto_generated_migration

# Optional MinIO local S3 profile (docker compose --profile local-s3)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
